{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "description": "Track Kafka + Confluent; major bumps wait for manual approval (need live-broker validation).",
  "schedule": ["before 6am on monday"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "lockFileMaintenance": { "enabled": false },
  "packageRules": [
    {
      "description": "Search Clojars, Maven Central, and Confluent.",
      "matchDatasources": ["clojure"],
      "registryUrls": [
        "https://repo.clojars.org",
        "https://repo.maven.apache.org/maven2",
        "https://packages.confluent.io/maven/"
      ]
    },
    {
      "matchManagers": ["leiningen"],
      "matchPackageNames": ["/^org\\.apache\\.kafka:/"],
      "groupName": "kafka"
    },
    {
      "matchManagers": ["leiningen"],
      "matchPackageNames": ["/^io\\.confluent:/"],
      "groupName": "confluent"
    },
    {
      "matchManagers": ["leiningen"],
      "matchPackageNames": ["/^org\\.apache\\.kafka:/", "/^io\\.confluent:/"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ],
  "github-actions": { "enabled": true }
}
